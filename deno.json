{
  "name": "denoweave",
  "version": "0.1.0",
  "exports": "./src/mod.ts",
  "description": "DenoWeave: a lightweight data transformation engine built in TypeScript + Deno",
  "tasks": {
    "test": "deno test --allow-read src/",
    "test:watch": "deno test --allow-read --watch src/",
    "run": "deno run --allow-read src/mod.ts",
    "cli": "deno run --allow-read src/cli/main.ts",
    "compile": "deno compile --allow-read --output build/denoweave src/cli/main.ts",
    "check": "deno check src/mod.ts",
    "lint": "deno lint",
    "fmt": "deno fmt"
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true
  },
  "fmt": { "indentWidth": 2, "singleQuote": true },
  "lint": { "rules": { "tags": ["recommended"] } },
  "imports": {
    "@denoweave/": "./src/",
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@std/yaml": "jsr:@std/yaml@^1.0.0"
  }
}
